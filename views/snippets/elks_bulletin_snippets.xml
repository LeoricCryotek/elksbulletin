<?xml version="1.0" encoding="utf-8"?>
<!-- =====================================================================
     === HUMAN ===
     Our custom "Lodge" building blocks for the newsletter editor, in two kinds:
       * STRUCTURAL blocks (full-width sections you stack to shape the page):
         Masthead, Section Bar, Message Block, In Memoriam, Lodge Officers,
         Two-Thirds + One-Third, Three Columns, Mailing Panel, and Page Break —
         Full Width.
       * INNER CONTENT blocks (drop INSIDE a column of the layout blocks; the
         column sizes them): the dynamic data blocks (New Members, Project
         Dollars, Dues, Charity, Calendar, Upcoming Events, Events), the
         hand-filled Member Photo Grid, Page Break — Inline, and the manual
         Continued On Page bar.
     They appear under a "Lodge" category in the block panel — and ONLY in this
     module's editor, not in Email Marketing.
     === AI AGENT ===
     Three parts: (1) inherit mass_mailing.email_designer_snippets to xpath our
     "lodge" snippet-group + blocks INTO the base's single snippet_groups /
     snippet_structure / snippet_content blocks. This is required: the
     html_builder snippet service keys categories by the <snippets> element id
     and OVERWRITES on duplicates (snippet_service.computeSnippetTemplates:
     snippetsByCategory[id] = ...), so a separate template that t-calls the base
     and appends its own <snippets id> blocks collides and hangs the panel.
     xpath-merging into the one base block is the supported pattern.
     (2) STRUCTURAL snippets = <template> whose root <section> carries
     o_mail_snippet_general (the inliner's addTables converts these to
     table>tr>td in body_html; the print resolver compensates).
     (3) INNER snippets = bare root element (div/p, NEVER <section>) +
     o_snippet_drop_in_only — core's s_inline_text pattern; a <section> root is
     what makes html_builder treat a block as a page-root structural drop.
     Shared conventions: o_elks_inner (print: unsplittable, tight margins),
     o_elks_bar (condensed purple header), data-elks-block / data-elks-field
     markers resolved at print by elks.bulletin.issue._render_print_body,
     s_elks_story_flow columns may split across pages and feed the
     auto-continuation pass. Styling is INLINE so it survives the mass_mailing
     email-inliner into body_html (used for print); classes and data-*
     attributes survive inlining, which is why all print-time hooks use them.
     NOTE: because the snippets template is shared, these blocks also appear in
     the Email Marketing designer. Scoping them to this module needs a
     different, separately-tested mechanism (see HANDOFF task 5) — not a second
     snippet set.
     ===================================================================== -->
<odoo>

    <!-- ============ (1) Register blocks into the panel ============ -->
    <template id="elksbulletin_email_designer_snippets"
              inherit_id="mass_mailing.email_designer_snippets">
        <xpath expr="//snippets[@id='snippet_groups']" position="inside">
            <t snippet-group="lodge" t-snippet="mass_mailing.s_snippet_group"
               string="Lodge"
               t-thumbnail="/mass_mailing/static/src/img/snippets_thumbs/s_title.svg"/>
        </xpath>
        <!-- Structural / layout blocks: full-width sections -->
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="elksbulletin.s_elks_masthead" string="Masthead" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_message.svg"/>
            <t t-snippet="elksbulletin.s_elks_section_bar" string="Section Bar" group="lodge"/>
            <t t-snippet="elksbulletin.s_elks_message" string="Message Block" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_message.svg"/>
            <t t-snippet="elksbulletin.s_elks_officers" string="Lodge Officers" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_officers.svg"/>
            <t t-snippet="elksbulletin.s_elks_two_thirds" string="Two-Thirds + One-Third" group="lodge"/>
            <t t-snippet="elksbulletin.s_elks_three_columns" string="Three Columns" group="lodge"/>
            <t t-snippet="elksbulletin.s_elks_mailing" string="Mailing Panel" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_mailing.svg"/>
            <t t-snippet="elksbulletin.s_elks_page_break" string="Page Break — Full Width" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_pagebreak.svg"/>
        </xpath>
        <!-- Dynamic data blocks live in INNER CONTENT so they can be dropped
             into a column (1/3, 2/3, 3/3) of the layout blocks above and sized
             to fit. Their content fills whatever width they're placed in. -->
        <xpath expr="//snippets[@id='snippet_content']" position="inside">
            <t t-snippet="elksbulletin.s_elks_new_members" string="New Members" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_members.svg"/>
            <t t-snippet="elksbulletin.s_elks_photo_grid" string="Member Photo Grid" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_members.svg"/>
            <t t-snippet="elksbulletin.s_elks_project_dollars" string="Project Dollars" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_money.svg"/>
            <t t-snippet="elksbulletin.s_elks_delinquents" string="Dues Report" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_dues.svg"/>
            <t t-snippet="elksbulletin.s_elks_charity" string="Charity Report" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_charity.svg"/>
            <t t-snippet="elksbulletin.s_elks_in_memoriam" string="In Memoriam" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_members.svg"/>
            <t t-snippet="elksbulletin.s_elks_calendar" string="Lodge Calendar" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_calendar.svg"/>
            <t t-snippet="elksbulletin.s_elks_page_break_inline" string="Page Break — Inline" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_pagebreak.svg"/>
            <t t-snippet="elksbulletin.s_elks_upcoming_events" string="Upcoming Events" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_events.svg"/>
            <t t-snippet="elksbulletin.s_elks_events" string="Events" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_events.svg"/>
            <t t-snippet="elksbulletin.s_elks_continued" string="Continued On Page" group="lodge"
               t-thumbnail="/elksbulletin/static/src/img/snippets_thumbs/ico_pagebreak.svg"/>
        </xpath>
    </template>

    <!-- ============ (2) Snippet templates ============ -->

    <!-- Masthead — Grand-Lodge-style banner (19.0.1.2.0). A purple-gradient band:
         top bar = Month | Website | Volume/No.; middle = B&W lodge logo (left) |
         lodge name (script) + NEWSLETTER (center) | lodge building photo (right);
         bottom = "Elks Care - Elks Share". Every dynamic bit carries a
         data-elks-field marker filled at print/preview from FRS lodge settings
         (elks.bulletin.issue._render_print_body): issue_month_year, lodge_website,
         issue_ref, lodge_name, logo_lodge_bw (falls back to colour logo),
         lodge_building_entry. Images default to Odoo's placeholder so the editor
         shows a grey box; the resolver swaps in the real image, or removes the
         <img> if FRS has none. Table layout (not flex) so the three-up middle row
         renders identically in the editor and in WeasyPrint. -->
    <template id="s_elks_masthead" name="Lodge Masthead">
        <section class="s_elks_masthead o_mail_snippet_general" data-name="Masthead">
            <div class="container" style="border:2px solid #3f2566;border-radius:8px;overflow:hidden;background-color:#8f78bd;background-image:linear-gradient(90deg,#6f57a4 0%,#ccc0e4 50%,#6f57a4 100%);">
                <!-- Top bar -->
                <table style="width:100%;border-collapse:collapse;background:#5b3b8c;">
                    <tr>
                        <td style="text-align:left;color:#ffffff;font-family:Arial,sans-serif;font-weight:bold;font-size:13px;letter-spacing:1px;text-transform:uppercase;padding:4px 14px;white-space:nowrap;"><span data-elks-field="issue_month_year">July 2026</span></td>
                        <td style="text-align:center;color:#ffffff;font-family:Arial,sans-serif;font-weight:bold;font-size:13px;padding:4px 8px;"><span data-elks-field="lodge_website">www.lewistonelks896.com</span></td>
                        <td style="text-align:right;color:#ffffff;font-family:Arial,sans-serif;font-weight:bold;font-size:13px;letter-spacing:1px;text-transform:uppercase;padding:4px 14px;white-space:nowrap;"><span data-elks-field="issue_ref">Volume 120, No. 7</span></td>
                    </tr>
                </table>
                <!-- Middle: logo | title | building photo -->
                <table style="width:100%;border-collapse:collapse;">
                    <tr>
                        <td style="width:20%;text-align:center;vertical-align:middle;padding:8px 6px;">
                            <img data-elks-field="logo_lodge_bw" src="/web/static/img/placeholder.png" alt="Lodge logo" style="max-height:96px;max-width:100%;"/>
                        </td>
                        <td style="width:56%;text-align:center;vertical-align:middle;padding:4px 0;">
                            <div style="font-family:Georgia,'Times New Roman',serif;font-style:italic;font-size:40px;line-height:1;color:#141414;"><span data-elks-field="lodge_name">Lewiston Elks Lodge</span></div>
                            <div style="font-family:Georgia,'Times New Roman',serif;font-weight:bold;font-size:46px;letter-spacing:3px;line-height:1;color:#141414;">NEWSLETTER</div>
                        </td>
                        <td style="width:24%;text-align:center;vertical-align:middle;padding:8px 6px;">
                            <img data-elks-field="lodge_building_entry" src="/web/static/img/placeholder.png" alt="Lodge building" style="max-height:104px;max-width:100%;border:1px solid #3f2566;"/>
                        </td>
                    </tr>
                </table>
                <!-- Tagline -->
                <div style="text-align:center;font-family:Georgia,'Times New Roman',serif;font-style:italic;font-size:22px;color:#141414;padding:0 0 8px;">Elks Care &#8212; Elks Share</div>
            </div>
        </section>
    </template>

    <!-- Purple section bar -->
    <template id="s_elks_section_bar" name="Section Bar">
        <section class="s_elks_section_bar o_mail_snippet_general pt8 pb8" data-name="Section Bar">
            <div class="container">
                <div style="background:#5b3b8c;color:#ffffff;text-align:center;font-family:Georgia,serif;font-weight:bold;letter-spacing:1px;font-size:18px;padding:4px 8px;border-radius:3px;">
                    Committee &amp; Lodge News
                </div>
            </div>
        </section>
    </template>

    <!-- Message Block: 2/3 message + 1/3 officer byline. Pick the officer with
         the "Officer" dropdown in the Style panel (sets an o_elks_officer_<pos>
         class); the title, photo, name and title then auto-fill from that officer
         in elks.officer.term at print. The message text stays editable. The class
         (not a data-attribute) is used because classes reliably survive the
         mass_mailing email inliner into body_html.
         NO BORDER by default (19.0.1.2.0): like every content/inner block, this
         ships frameless so the page reads clean; add a Border / Round Corners in
         the Style panel (on the Column) where a boxed look is wanted. Only the
         inner padding is kept so text isn't flush to the section edge. -->
    <template id="s_elks_message" name="Message Block">
        <section class="s_elks_message o_mail_snippet_general pt16 pb16 o_elks_officer_exalted_ruler" data-name="Message Block">
            <div class="container" style="padding:12px 16px;">
                <h1 class="s_elks_msg_title" style="font-family:Arial,sans-serif;font-weight:900;color:#000000;font-size:34px;line-height:1;margin:0 0 10px;">Officer's Message</h1>
                <div class="row">
                    <div class="col-md-8 col-12 s_elks_story_flow">
                        <p style="text-align:justify;">Replace this with your message. Use the <b>Officer</b> dropdown in the Style panel to choose whose message this is &#8212; the title, photo, name and title fill in automatically on Print / Preview.</p>
                    </div>
                    <div class="col-md-4 col-12 s_elks_msg_byline" style="text-align:center;">
                        <div style="width:100%;max-width:150px;height:150px;background:#8b8b8b;border:1px solid #555555;margin:0 auto;"></div>
                        <p style="font-family:Arial,sans-serif;font-weight:bold;color:#000000;margin-top:6px;">Officer Name<br/><span style="font-weight:normal;font-style:italic;color:#3f2566;">Title</span></p>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!-- In Memoriam: gold-accented box. INNER CONTENT (19.0.1.2.0): a bare div +
         o_snippet_drop_in_only (same pattern as the other dynamic blocks) so it
         drops INSIDE a layout column (1/3, 2/3, 3/3) and is sized by that column,
         instead of being a full-width section. DYNAMIC: the names list
         (data-elks-block="in_memoriam") auto-fills at print/preview with members
         flagged deceased whose Date of Death is in the CALENDAR MONTH BEFORE the
         issue date (see elks.bulletin.issue._html_in_memoriam). The gold frame,
         header and the fraternal quote stay static. The decorative gold border +
         rounded corners are baked inline on the frame (print via WeasyPrint's
         border-radius). o_elks_inner keeps it whole across page turns. -->
    <template id="s_elks_in_memoriam" name="In Memoriam">
        <div class="s_elks_in_memoriam o_elks_inner o_snippet_drop_in_only" data-name="In Memoriam">
            <div style="border:2px solid #c9a227;border-radius:8px;background:#f7efd6;padding:12px 16px;text-align:center;">
                <div style="background:#c9a227;color:#3f2566;font-family:Arial,sans-serif;font-weight:bold;text-transform:uppercase;letter-spacing:1px;padding:3px;border-radius:3px;">In Memoriam</div>
                <div data-elks-block="in_memoriam">
                    <p style="text-align:center;color:#777;font-style:italic;font-family:Arial,sans-serif;font-size:12px;margin:8px 0 0;">Auto-fills with members who passed in the month before this issue when you Print / Preview.</p>
                </div>
                <p style="font-family:Georgia,serif;font-style:italic;color:#5b3b8c;border-top:1px solid #c9a227;border-bottom:1px solid #c9a227;padding:8px 0;margin:10px 0 0;">&#8220;The faults of our members we write upon the sand; their virtues upon the tablets of love and memory.&#8221;</p>
            </div>
        </div>
    </template>

    <!-- Lodge Officers strip — DYNAMIC: auto-fills from elks.officer.term for the
         issue's lodge year at print/preview. -->
    <template id="s_elks_officers" name="Lodge Officers">
        <section class="s_elks_officers o_mail_snippet_general pt8 pb8" data-name="Officers">
            <div class="container" style="padding:2px 0;">
                <div style="background:#5b3b8c;color:#ffffff;text-align:center;font-family:Georgia,serif;font-weight:bold;letter-spacing:1px;padding:3px;border-radius:3px;margin-bottom:6px;">Lodge Officers</div>
                <div data-elks-block="officers">
                    <p style="text-align:center;color:#777;font-style:italic;font-family:Arial,sans-serif;font-size:12px;margin:4px 0;">Auto-fills with the lodge officers for this issue's lodge year when you Print / Preview.</p>
                </div>
            </div>
        </section>
    </template>

    <!-- Two-Thirds + One-Third layout. Columns are plain so the editor's Style
         panel (Border / Round Corners / Padding on the Column) is the single
         box control — no baked-in box to fight with. -->
    <template id="s_elks_two_thirds" name="Two-Thirds + One-Third">
        <section class="s_elks_two_thirds o_mail_snippet_general pt16 pb16" data-name="Two-Thirds + One-Third">
            <div class="container">
                <div class="row">
                    <div class="col-md-8 col-12 s_elks_story_flow">
                        <h2 style="font-family:Arial,sans-serif;font-weight:900;color:#000000;font-size:24px;margin:0 0 6px;">Main Story</h2>
                        <p style="text-align:justify;">Two-thirds column for the lead article. Drag text and images here, or type directly to replace this copy.</p>
                    </div>
                    <div class="col-md-4 col-12">
                        <h3 style="font-family:Arial,sans-serif;font-weight:bold;color:#3f2566;font-size:16px;margin:0 0 6px;">Sidebar</h3>
                        <p style="text-align:justify;">One-third column for a short note, box, or announcement.</p>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!-- Three equal columns. Plain columns; box is controlled via the Style
         panel (see note above). -->
    <template id="s_elks_three_columns" name="Three Columns">
        <section class="s_elks_three_columns o_mail_snippet_general pt16 pb16" data-name="Three Columns">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 col-12 s_elks_story_flow">
                        <h3 style="font-family:Arial,sans-serif;font-weight:bold;color:#3f2566;font-size:15px;margin:0 0 6px;">Column One</h3>
                        <p style="text-align:justify;">Equal thirds for briefs and notes around the lodge.</p>
                    </div>
                    <div class="col-md-4 col-12 s_elks_story_flow">
                        <h3 style="font-family:Arial,sans-serif;font-weight:bold;color:#3f2566;font-size:15px;margin:0 0 6px;">Column Two</h3>
                        <p style="text-align:justify;">Equal thirds for briefs and notes around the lodge.</p>
                    </div>
                    <div class="col-md-4 col-12 s_elks_story_flow">
                        <h3 style="font-family:Arial,sans-serif;font-weight:bold;color:#3f2566;font-size:15px;margin:0 0 6px;">Column Three</h3>
                        <p style="text-align:justify;">Equal thirds for briefs and notes around the lodge.</p>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!-- Continued-on-page bar. TRUE inner content: bare div + o_snippet_drop_in_only
         (matching core's s_inline_text/s_button/s_image pattern in
         mass_mailing_inner_snippets.xml), NOT a <section>+<container> wrapper.
         A <section> root is what makes html_builder treat a block as a
         standalone structural drop (page-root only); wrapping this in one made
         it land as its own full-width row instead of nesting into a story's
         flow, which defeated the point of a manual continuation marker. Default
         text is editable in place. For most cases you won't need this anymore:
         the auto-continuation pass (ir_actions_report._bulletin_insert_continuation_markers)
         inserts one of these automatically wherever a .s_elks_story_flow column
         actually breaks across pages. Keep this for one-off manual placement
         outside a story flow. -->
    <template id="s_elks_continued" name="Continued On Page">
        <div class="s_elks_continued o_snippet_drop_in_only" style="background:#d7d2dd;text-align:center;font-family:Georgia,serif;font-style:italic;font-size:13px;padding:4px;">Continued on page #</div>
    </template>

    <!-- Member Photo Grid: STATIC, fully hand-editable photo cards for the
         real-world workflow where new-member photos are taken at initiation
         and EMAILED to whoever assembles the newsletter (they are usually not
         on the member's contact record, so the dynamic New Members photo mode
         has nothing to pull). Drop this under the New Members block, then
         double-click each placeholder image and upload the emailed photo;
         the name/caption lines are ordinary editable text. Duplicate a card
         (or the whole block) from its editor toolbar for more members.
         No data-elks-block marker on purpose: the print resolver leaves this
         block completely alone, so manual edits are never overwritten.
         TIP: photos uploaded to the member's CONTACT record instead would
         appear automatically via the New Members block's photo mode. -->
    <template id="s_elks_photo_grid" name="Member Photo Grid">
        <div class="s_elks_photo_grid o_snippet_drop_in_only">
            <table style="width:100%;border-collapse:collapse;">
                <tr>
                    <td style="width:33%;text-align:center;vertical-align:top;padding:8px 4px;">
                        <img src="/web/static/img/placeholder.png" alt="Member photo" style="width:88px;height:88px;border-radius:50%;object-fit:cover;border:2px solid #3f2566;"/>
                        <div style="font-family:Georgia,serif;font-weight:bold;font-size:13px;margin-top:4px;">Member Name</div>
                        <div style="font-family:Arial,sans-serif;font-size:11px;color:#555;">Initiated &#8212; date</div>
                    </td>
                    <td style="width:33%;text-align:center;vertical-align:top;padding:8px 4px;">
                        <img src="/web/static/img/placeholder.png" alt="Member photo" style="width:88px;height:88px;border-radius:50%;object-fit:cover;border:2px solid #3f2566;"/>
                        <div style="font-family:Georgia,serif;font-weight:bold;font-size:13px;margin-top:4px;">Member Name</div>
                        <div style="font-family:Arial,sans-serif;font-size:11px;color:#555;">Initiated &#8212; date</div>
                    </td>
                    <td style="width:33%;text-align:center;vertical-align:top;padding:8px 4px;">
                        <img src="/web/static/img/placeholder.png" alt="Member photo" style="width:88px;height:88px;border-radius:50%;object-fit:cover;border:2px solid #3f2566;"/>
                        <div style="font-family:Georgia,serif;font-weight:bold;font-size:13px;margin-top:4px;">Member Name</div>
                        <div style="font-family:Arial,sans-serif;font-size:11px;color:#555;">Initiated &#8212; date</div>
                    </td>
                </tr>
            </table>
        </div>
    </template>

    <!-- ============ Dynamic blocks ============ -->
    <!-- Each carries a data-elks-block marker. In the editor you see the
         placeholder text; the real data is injected at print/preview by
         elks.bulletin.issue._render_print_body(). -->

    <!-- Dynamic blocks are TRUE INNER CONTENT (bare div + o_snippet_drop_in_only,
         same pattern as core's s_inline_text): droppable INSIDE a column of the
         structural layout blocks (Two-Thirds, Three Columns, Message) and sized
         by that column — not standalone full-width sections. Shared classes:
         o_elks_inner (print: keep whole across page turns, tight margins) and
         o_elks_bar on the purple header (print + editor: condensed padding).
         The structural blocks (Masthead, Section Bar, Message, In Memoriam,
         Officers, layouts, Mailing, Page Break — Full Width) remain sections. -->

    <!-- New Members (name / age / initiation date) -->
    <template id="s_elks_new_members" name="New Members (Dynamic)">
        <div class="s_elks_new_members o_elks_inner o_snippet_drop_in_only" data-name="New Members (Dynamic)">
            <div class="o_elks_bar" style="background:#5b3b8c;color:#ffffff;text-align:center;font-family:Georgia,serif;font-weight:bold;letter-spacing:1px;padding:2px;border-radius:3px;margin-bottom:3px;">Welcome Our New Members</div>
            <div data-elks-block="new_members">
                <p style="text-align:center;color:#777;font-style:italic;font-family:Arial,sans-serif;font-size:12px;margin:4px 0;">Auto-fills with new members (name, age, initiation date; veterans flagged) when you Print / Preview.</p>
            </div>
        </div>
    </template>

    <!-- Project Dollars total (fiscal year) -->
    <template id="s_elks_project_dollars" name="Project Dollars (Dynamic)">
        <div class="s_elks_project_dollars o_elks_inner o_snippet_drop_in_only" data-name="Project Dollars (Dynamic)">
            <div class="o_elks_bar" style="background:#5b3b8c;color:#ffffff;text-align:center;font-family:Georgia,serif;font-weight:bold;letter-spacing:1px;padding:2px;border-radius:3px;margin-bottom:3px;">Project Dollars</div>
            <div data-elks-block="project_dollars">
                <p style="text-align:center;color:#777;font-style:italic;font-family:Arial,sans-serif;font-size:12px;margin:4px 0;">Auto-fills with the fiscal-year Project Dollars total (Secretary's meeting-money reports) when you Print / Preview.</p>
            </div>
        </div>
    </template>

    <!-- Dues report (counts only) -->
