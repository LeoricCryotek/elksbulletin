    <!-- Page Break: forces the next content onto a new printed page. The dashed
         line shows in the editor; it is invisible in the PDF (see report CSS
         .s_elks_page_break). Use it wherever wkhtmltopdf's auto avoid isn't
         enough. -->
    <template id="s_elks_page_break" name="Page Break">
        <section class="s_elks_page_break o_mail_snippet_general pt8 pb8" data-name="Page Break">
            <div class="container">
                <div class="s_elks_page_break_line" style="border-top:2px dashed #b39ddb;text-align:center;color:#8e7cc3;font-family:Arial,sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;padding-top:3px;">&#9986; Page Break</div>
            </div>
        </section>
    </template>

    <!-- Page Break (Inline): same forced break, but TRUE inner content (bare div
         + o_snippet_drop_in_only, like the Continued bar above) so it can be
         dropped INSIDE a story column mid-text (e.g. between two paragraphs of
         an Officer's Message) instead of only between full-width sections.
         Invisible in the PDF (report CSS .s_elks_page_break_inline).
         LIMITATION: only effective inside FULL-WIDTH blocks (Message Block,
         Two-Thirds + One-Third, Three Columns). Inside a SIZED side-by-side
         block (o_elks_w_23/_12/_13) it does nothing: those render as
         inline-block in print, and inline-block boxes are atomic for CSS
         fragmentation; a break-after inside one cannot split it.
         The auto-continuation pass deliberately skips this element when
         assigning elks-flow ids (issue resolver step 5), so the
         "Continued on page #" bar pairs the paragraphs AROUND the break and
         lands on the correct side of it (bottom of the earlier page). -->
    <template id="s_elks_page_break_inline" name="Page Break (Inline)">
        <div class="s_elks_page_break_inline o_snippet_drop_in_only" style="border-top:2px dashed #b39ddb;text-align:center;color:#8e7cc3;font-family:Arial,sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;padding-top:3px;">&#9986; Page Break</div>
    </template>

