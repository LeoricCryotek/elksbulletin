<?xml version="1.0" encoding="utf-8"?>
<!-- =====================================================================
     === HUMAN ===
     The backend screens: the newsletter list + editing form (with the
     page content area), and the template list/form.
     === AI AGENT ===
     body_html uses widget="html" for now (a placeholder for the full snippet
     drag-drop editor configured in the editor phase). charter_missing drives a
     warning banner. Actions are referenced by the menus file.
     ===================================================================== -->
<odoo>

    <!-- ============== Newsletter Issue: form ============== -->
    <record id="view_elks_bulletin_issue_form" model="ir.ui.view">
        <field name="name">elks.bulletin.issue.form</field>
        <field name="model">elks.bulletin.issue</field>
        <field name="arch" type="xml">
            <form string="Newsletter" class="o_elksbulletin_form">
                <header>
                    <button name="action_preview_pdf" type="object"
                            string="Preview" class="btn-secondary"
                            icon="fa-eye"/>
                    <button name="action_print_pdf" type="object"
                            string="Print / Download PDF" class="btn-primary"
                            icon="fa-file-pdf-o"/>
                    <button name="action_mark_final" type="object"
                            string="Mark Final"
                            invisible="state == 'final'"
                            groups="elksbulletin.group_elksbulletin_manager"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state == 'draft'"
                            groups="elksbulletin.group_elksbulletin_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,final"/>
                </header>
                <sheet>
                    <field name="charter_missing" invisible="1"/>
                    <div class="alert alert-warning" role="alert"
                         invisible="not charter_missing">
                        The lodge <b>charter date</b> isn't set in FRS, so the
                        masthead can't show the Volume yet. Set it in the FRS
                        Lodge Settings and it fills in automatically.
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"
                                   placeholder="Lodge Newsletter — Month Year"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="issue_date"/>
                            <field name="page_size"/>
                            <field name="template_id"/>
                        </group>
                        <group>
                            <field name="issue_ref" readonly="1"/>
                            <field name="lodge_name" readonly="1"/>
                        </group>
                    </group>
                    <group string="Dynamic Block Settings"
                           help="Control the auto-filled New Members block.">
                        <group>
                            <field name="new_member_month"/>
                        </group>
                        <group>
                            <field name="new_member_photos"/>
                        </group>
                    </group>
                    <separator string="Newsletter"/>
                    <field name="mailing_model_id" invisible="1"/>
                    <field name="body_html" invisible="1"/>
                    <field name="body_arch" widget="mass_mailing_html"
                           options="{'inline_field': 'body_html'}"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============== Newsletter Issue: list ============== -->
    <record id="view_elks_bulletin_issue_list" model="ir.ui.view">
        <field name="name">elks.bulletin.issue.list</field>
        <field name="model">elks.bulletin.issue</field>
        <field name="arch" type="xml">
            <list string="Newsletters">
                <field name="name"/>
                <field name="issue_date"/>
                <field name="issue_ref"/>
                <field name="page_size"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'final'"/>
            </list>
        </field>
    </record>

    <record id="action_elks_bulletin_issue" model="ir.actions.act_window">
        <field name="name">Newsletters</field>
        <field name="res_model">elks.bulletin.issue</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first newsletter</p>
            <p>New issues start from the default <b>Lodge Newsletter</b> template.</p>
        </field>
    </record>

    <!-- ============== Template: form + list ============== -->
    <record id="view_elks_bulletin_template_form" model="ir.ui.view">
        <field name="name">elks.bulletin.template.form</field>
        <field name="model">elks.bulletin.template</field>
        <field name="arch" type="xml">
            <form string="Newsletter Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template name"/></h1>
                    </div>
                    <group>
                        <field name="is_default"/>
                    </group>
                    <separator string="Layout"/>
                    <field name="mailing_model_id" invisible="1"/>
                    <field name="body_html" invisible="1"/>
                    <field name="body_arch" widget="mass_mailing_html"
                           options="{'inline_field': 'body_html'}"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_elks_bulletin_template_list" model="ir.ui.view">
        <field name="name">elks.bulletin.template.list</field>
        <field name="model">elks.bulletin.template</field>
        <field name="arch" type="xml">
            <list string="Templates">
                <field name="name"/>
                <field name="is_default"/>
            </list>
        </field>
    </record>

    <record id="action_elks_bulletin_template" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">elks.bulletin.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
