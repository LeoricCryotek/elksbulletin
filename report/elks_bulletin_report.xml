<?xml version="1.0" encoding="utf-8"?>
<!-- =====================================================================
     === HUMAN ===
     The print/PDF export for a newsletter issue. It turns the drag-and-drop
     page into a page-sized PDF (US Letter or US Legal), adds a page-number
     footer ("Page 1 of 4"), keeps blocks from splitting mid-box, and treats a
     "Continued On Page" block as a real page break. There are two page sizes,
     so there are two matching paper formats; the issue picks the right one.
     === AI AGENT ===
     wkhtmltopdf path (Odoo 19 still shells out to wkhtmltopdf). Layout:
       * body  -> <div class="article" data-oe-model/-id/-lang> (ir_actions_report
         ._prepare_html extracts nodes by class 'article' as the body).
       * footer-> <div class="footer"> with <span class="page"/> / <span
         class="topage"/> (wkhtmltopdf substitutes real page numbers via the
         web.minimal_layout JS trick). Footer inline-styled (rendered as its own
         mini-document, page CSS does not reach it).
     Two report actions share one inner document template; each carries its own
     paperformat so the model can choose Letter vs Legal by page_size. Print CSS
     is injected INSIDE the article so it scopes into the rendered body: widens
     the email .container to full page width, prevents block bleed, forces the
     continued-block page break. Model/view/report changes require -u elksbulletin.
     ===================================================================== -->
<odoo>

    <!-- ================= Paper formats ================= -->
    <!-- US Letter (built-in size). Bottom margin reserves footer space. -->
    <record id="paperformat_bulletin_letter" model="report.paperformat">
        <field name="name">Lodge Newsletter — US Letter</field>
        <field name="default" eval="False"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">14</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
        <field name="disable_shrinking" eval="True"/>
    </record>

    <!-- US Legal (built-in size). -->
    <record id="paperformat_bulletin_legal" model="report.paperformat">
        <field name="name">Lodge Newsletter — US Legal</field>
        <field name="default" eval="False"/>
        <field name="format">Legal</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">14</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
        <field name="disable_shrinking" eval="True"/>
    </record>

    <!-- ================= Report actions (Letter / Legal) ================= -->
    <record id="action_report_bulletin_letter" model="ir.actions.report">
        <field name="name">Newsletter (Letter)</field>
        <field name="model">elks.bulletin.issue</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">elksbulletin.report_bulletin_letter</field>
        <field name="report_file">elksbulletin.report_bulletin_letter</field>
        <field name="paperformat_id" ref="paperformat_bulletin_letter"/>
        <field name="print_report_name">(object.name or 'Newsletter')</field>
    </record>

    <record id="action_report_bulletin_legal" model="ir.actions.report">
        <field name="name">Newsletter (Legal)</field>
        <field name="model">elks.bulletin.issue</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">elksbulletin.report_bulletin_legal</field>
        <field name="report_file">elksbulletin.report_bulletin_legal</field>
        <field name="paperformat_id" ref="paperformat_bulletin_legal"/>
        <field name="print_report_name">(object.name or 'Newsletter')</field>
    </record>

    <!-- ================= Thin wrappers -> shared document ================= -->
    <template id="report_bulletin_letter">
        <t t-call="elksbulletin.report_bulletin_document"/>
    </template>
    <template id="report_bulletin_legal">
        <t t-call="elksbulletin.report_bulletin_document"/>
    </template>

    <!-- ================= Shared document template ================= -->
    <!-- Rendered by WeasyPrint (see models/ir_actions_report.py) which supports
         real CSS paged media: @page size/margins + margin-box footer, CSS
         multicol with column-span, and break-inside: avoid. -->
    <template id="report_bulletin_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="article"
                     t-att-data-oe-model="doc and doc._name"
                     t-att-data-oe-id="doc and doc.id"
                     t-att-data-oe-lang="doc and doc.env.context.get('lang')">

                    <style>
                        /* -------- Page + running footer (page numbers) -------- */
                        @page {
                            size: <t t-esc="'8.5in 14in' if doc.page_size == 'legal' else '8.5in 11in'"/>;
                            margin: 0.5in 0.5in 0.62in 0.5in;
                            @bottom-left {
                                content: "<t t-esc="doc.lodge_name or 'Lewiston Elks Lodge'"/> No. <t t-esc="doc.lodge_number or ''"/> \00B7 B.P.O.E.";
                                font: 8.5pt Arial, sans-serif; color: #3f2566;
                            }
                            @bottom-center {
                                content: "Page " counter(page) " of " counter(pages);
                                font: bold 8.5pt Arial, sans-serif; color: #3f2566;
                            }
                            @bottom-right {
                                content: "<t t-esc="doc.issue_date.strftime('%B %Y') if doc.issue_date else ''"/>";
                                font: 8.5pt Arial, sans-serif; color: #3f2566;
                            }
                        }

                        body { font-family: Georgia, 'Times New Roman', serif; color: #111; }
                        * { box-sizing: border-box; }
                        img { max-width: 100%; height: auto; }
                        .container, .container-fluid { max-width: 100% !important; width: 100% !important; padding-left: 0 !important; padding-right: 0 !important; margin-left: 0 !important; margin-right: 0 !important; }

                        /* -------- Layout: full-width blocks are BLOCK level (so
                           break-inside: avoid keeps them whole); only blocks you
                           size in the Style panel become inline-block and sit side
                           by side. font-size:0 on the flow removes the whitespace
                           gap between adjacent sized inline-blocks. -->
                        .o_elks_print_flow { font-size: 0; }
                        .o_mail_print_wrapper { display: block; width: 100%; }
                        .o_mail_snippet_general {
                            display: block; width: 100%;
                            box-sizing: border-box; font-size: 12px;
                            break-inside: avoid; margin-bottom: 9px; line-height: 1.25;
                        }
                        .o_mail_snippet_general p { margin: 0 0 4px; line-height: 1.25; }
                        .o_mail_snippet_general tr, .o_mail_snippet_general img { break-inside: avoid; }

                        /* Per-block Width (Style panel): sized blocks go inline-block
                           and sit side by side. Fractions a touch under exact so
                           adjacent blocks fit on one row. */
                        .o_mail_snippet_general.o_elks_w_full { display: block; width: 100%; }
                        .o_mail_snippet_general.o_elks_w_23 { display: inline-block; vertical-align: top; width: 66%; }
                        .o_mail_snippet_general.o_elks_w_12 { display: inline-block; vertical-align: top; width: 49.6%; }
                        .o_mail_snippet_general.o_elks_w_13 { display: inline-block; vertical-align: top; width: 33%; }

                        /* Lodge Calendar: scale the published calendar down to fit a
                           portrait page (its cells are sized for a landscape sheet). */
                        .s_elks_calendar .elks-cal table.grid-table td.cell { height: 58px !important; font-size: 9px !important; padding: 2px 4px 3px !important; }
                        .s_elks_calendar .elks-cal .month, .s_elks_calendar .elks-cal .year { font-size: 30px !important; }
                        .s_elks_calendar .elks-cal .deco { font-size: 15px !important; letter-spacing: 2px !important; }
                        .s_elks_calendar .elks-cal table.grid-table th { font-size: 11px !important; padding: 2px 0 3px !important; }
                        .s_elks_calendar .elks-cal .cell .num { font-size: 9px !important; }
                        .s_elks_calendar .elks-cal .cell .event-line,
                        .s_elks_calendar .elks-cal .cell .holiday,
                        .s_elks_calendar .elks-cal .cell .event-time,
                        .s_elks_calendar .elks-cal .cell .banner-headline,
                        .s_elks_calendar .elks-cal .cell .banner-sub { font-size: 8px !important; line-height: 1.15 !important; }
                        .s_elks_calendar .elks-cal .footer-note { font-size: 9px !important; margin-top: 3px !important; }

                        /* Manual Page Break: force a new page; hide its editor line */
                        .s_elks_page_break { display: block; width: 100%; break-after: page; }
                        .s_elks_page_break_line { border: 0 !important; color: transparent !important; height: 0 !important; padding: 0 !important; }
                        /* Inline Page Break: droppable mid-story; forces a break
                           there and vanishes in print. Only effective inside
                           full-width blocks -- inline-block (sized) boxes are
                           atomic for CSS fragmentation and cannot be split. */
                        .s_elks_page_break_inline {
                            display: block; width: 100%;
                            break-after: page; page-break-after: always;
                            border: 0 !important; color: transparent !important;
                            font-size: 0 !important; height: 0 !important;
                            padding: 0 !important; margin: 0 !important;
                            overflow: hidden;
                        }
                        .s_elks_masthead { break-after: avoid; }

                        /* Auto "Continued on page #" bars, inserted at the real
                           page-break boundary by the report's second WeasyPrint
                           pass (ir_actions_report._bulletin_insert_continuation_markers).
                           Also used by the manual "Continued On Page" snippet. */
                        .s_elks_continued, .s_elks_continued_auto, .s_elks_continued_from_auto {
                            break-inside: avoid; page-break-inside: avoid;
                        }

                        /* Story flow: long-form body text (Message Block /
                           Two-Thirds+One-Third / Three Columns) is allowed to
                           split naturally across pages -- the auto-continuation
                           pass marks the real break point -- instead of being
                           dragged whole onto the next page by the section-level
                           break-inside: avoid above. Headings stay glued to their
                           first line so a heading never sits alone at page-bottom. */
                        .s_elks_story_flow { break-inside: auto; page-break-inside: auto; }
                        .s_elks_story_flow h1, .s_elks_story_flow h2, .s_elks_story_flow h3 {
                            break-after: avoid; page-break-after: avoid;
                        }

                        /* Lodge Calendar grid: keep each week row (and its
                           cells) from splitting mid-row. The .o_mail_snippet_general
                           tr rule below doesn't reach into the publisher's own
                           .elks-cal table markup, which uses its own class scope. */
                        .s_elks_calendar .elks-cal table.grid-table tr,
                        .s_elks_calendar .elks-cal table.grid-table td.cell {
                            break-inside: avoid; page-break-inside: avoid;
                        }
                    </style>

                    <!-- Drag-and-drop page (email-inlined HTML) with dynamic Lodge
                         blocks filled in, wrapper table flattened, and the section
                         holder tagged .o_elks_print_flow for column flow. -->
                    <t t-out="doc._render_print_body()"/>
                </div>
            </t>
        </t>
    </template>

</odoo>
